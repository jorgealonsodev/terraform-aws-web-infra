# Terraform state and lock files
.terraform/
*.tfstate
*.tfstate.backup
*.tfstate.*
# Auto-loaded tfvars (terraform automatically loads *.auto.tfvars)
*.auto.tfvars
# Allow the intentional terraform.tfvars defaults file
!terraform.tfvars

# NOTE: .terraform.lock.hcl is intentionally NOT ignored — it must be versioned
# to ensure reproducible provider versions across environments and CI.

# IDE and editor files
.atl/
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Secrets and credentials
*.pem
*.key
credentials
